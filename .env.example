# ToyBox Egypt - Environment Variables Example
# Copy this file to .env.local and fill in your values

# API Keys (if needed in future)
# VITE_API_KEY=your_api_key_here

# Analytics (optional)
# VITE_GA_TRACKING_ID=your_google_analytics_id

# Contact Information
VITE_CONTACT_EMAIL=hello@toyboxegypt.com
VITE_CONTACT_PHONE=+20 100 123 4567
VITE_CONTACT_ADDRESS=Cairo, Egypt

# Social Media (optional)
# VITE_FACEBOOK_URL=https://facebook.com/toyboxegypt
# VITE_INSTAGRAM_URL=https://instagram.com/toyboxegypt
